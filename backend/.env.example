# ====================================================================
# 配送小智 - 后端环境变量示例
# 复制为 .env 并填入真实值（不要提交 .env 到 Git）
# ====================================================================

# 基础配置
PORT=3000
NODE_ENV=production

# CORS 严格配置（生产环境必须为具体域名，多个用逗号分隔）
# CORS_ORIGIN=https://peisong.example.com,https://admin.example.com
CORS_ORIGIN=*

# JWT 强随机密钥（生产必须使用 64 字节随机串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=b2de57cc06d08988c5d60754828ba047642897655bf21d17f8b688173889144fa122b34ebb699c43ceede799abe8a2a726ea72e882cc588d320f4845d7f77e14
JWT_EXPIRES_IN=7d

# 密码加密（bcrypt rounds，越大越安全但越慢，推荐 12）
BCRYPT_ROUNDS=12

# 限流（每 IP 每分钟最大请求数）
RATE_LIMIT_PER_MINUTE=300

# 数据库（可选 - 不配置则用 JSON 降级方案）
# 格式：postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://peisong:yourpassword@localhost:5432/peisong

# 调试模式（生产必须为 false）
DEBUG_MODE=false
LOG_LEVEL=info

# AI 决策（Coze Bot 接入）
COZE_API_URL=https://api.coze.cn/v3/chat
COZE_BOT_ID=your_bot_id_here
COZE_API_KEY=your_api_key_here
COZE_USER_ID=demo

# ====== LLM 多模型路由（豆包 / DeepSeek / Coze） ======
# 豆包 Doubao（字节火山引擎）https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here
# 模型名两种方式（任选一个）：
# 1. 标准模型名（包含 Doubao-Seed-2.1-pro / Doubao-pro-32k 等）
# 2. 自定义 endpoint ID（ep-2024xxxx-xxxxx，开通后从在线推理页面获取）
DOUBAO_MODEL=Doubao-Seed-2.1-pro
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# DeepSeek（备用）https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# LLM 路由策略: auto | doubao | deepseek | coze
# auto: 根据任务自动选（豆包优先 → DeepSeek → Coze → mock）
LLM_STRATEGY=auto
LLM_DEFAULT=doubao

# ====================================================================
# 4 个真实数据接入端口
# ====================================================================

# 1) 饿了么 Open API（历史订单）
# 申请: https://open.ele.me/
# 需公司 OAuth 授权
# ELEME_APP_KEY=
# ELEME_APP_SECRET=
# ELEME_ACCESS_TOKEN=
# ELEME_API_URL=https://open-api.shop.ele.me/api/v1

# 2) 骑手位置 SDK（实时位置）
# 需 App 集成 SDK，通过 WebSocket 推送
# RIDER_WS_URL=
# RIDER_API_TOKEN=

# 3) 和风天气 API（实时天气）
# 申请: https://dev.qweather.com/
# 个人开发者免费（每天 1000 次调用）
# 申请后填入 API Key 即可
# QWEATHER_API_KEY=your_qweather_key_here
# QWEATHER_API_HOST=https://devapi.qweather.com/v7

# 4) 订单流 WebSocket（实时订单）
# 需公司订单系统接入
# ORDER_STREAM_URL=
# ORDER_API_TOKEN=

# ====================================================================
# 部署说明
# ====================================================================
#
# 1) 本地开发：复制为 .env，填入你自己的 key
# 2) GitHub Pages 部署前端：不用管后端
# 3) Render 部署后端：在 Render Dashboard 设置环境变量
# 4) 没填 key 的端口：自动用 Mock 真实业务数据
#
# 推荐：
# - 和风天气 API Key：必填（10 分钟搞定，免费）
# - 其他 3 个：可暂用 Mock，等公司授权后切换
#
